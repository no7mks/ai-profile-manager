#!/usr/bin/env php
<?php

declare(strict_types=1);

use AiProfileManager\Core\Application;

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php', // Run from repository root during local development.
    __DIR__ . '/../../../autoload.php', // Composer global bin proxy under vendor/bin.
    __DIR__ . '/../../autoload.php', // Direct package bin execution under vendor/<vendor>/<package>/bin.
];

$autoload = null;
foreach ($autoloadCandidates as $candidate) {
    if (file_exists($candidate)) {
        $autoload = $candidate;
        break;
    }
}

if ($autoload === null) {
    fwrite(STDERR, "Missing dependencies. Run: composer install\n");
    exit(1);
}
require $autoload;

$app = new Application();
exit($app->run($argv));
